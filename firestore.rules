rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: history
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID of the person who performed the analysis.
    //   - timestamp: number (required) - The time the analysis was performed.
    //   - drugs: list (required) - The list of drugs analyzed.
    //   - result: map (required) - The result of the analysis.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidHistoryEntry(data) {
      return hasRequiredFields(['uid', 'timestamp', 'drugs', 'result']) &&
             hasOnlyAllowedFields(['uid', 'timestamp', 'drugs', 'result']) &&
             data.uid is string &&
             data.timestamp is number &&
             data.drugs is list &&
             data.result is map;
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && isDocOwner();
      allow create: if isAuthenticated() && isValidHistoryEntry(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidHistoryEntry(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
